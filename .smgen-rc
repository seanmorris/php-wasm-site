#!/usr/bin/env bash

TITLE_PREFIX=${TITLE_PREFIX:-"Php-Wasm"}
BASE_URL=${BASE_URL:-"https://php-wasm.seanmorr.is"}
STATIC_DIR=${STATIC_DIR:-"./static"}
UUID=${UUID:-"uuidgen"}

STYLES=$( cat <<-END
	/style.css
	/article.css
	/pandoc.css
END
)

INLINE_STYLES=$( cat <<-END
	${STATIC_DIR}/heading.css
	${STATIC_DIR}/fonts.css
END
)

SCRIPTS=$( cat <<-END
	/main.js
END
)

